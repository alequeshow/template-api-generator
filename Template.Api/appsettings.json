{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Error"
    }
  },
  "AllowedHosts": "*",
  "MongoConfiguration": {
    "ConnectionString": "mongodb://appuser:apppassword123@localhost:27017/template_api_db?authSource=template_api_db"
  },
  "JwtSettings": {
    "Secret": "<YourSuperSecretKeyThatShouldBeAtLeast32CharactersLong!>",
    "Issuer": "Template.Api",
    "Audience": "Template.Client",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  }
}
