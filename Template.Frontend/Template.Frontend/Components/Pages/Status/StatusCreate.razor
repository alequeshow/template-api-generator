@page "/status/create"

@using Microsoft.AspNetCore.Authorization
@using Template.Contract
@using Template.Frontend.Services.Interfaces.ApiClients
@inject IStatusApiClient _statusClient
@attribute [Authorize]

<PageTitle>Status Creation</PageTitle>

<h1>Create Status</h1>

<AlertMessage Message="@_message" Type="@_alertType"/>

<EditForm Model="@StatusModel" OnValidSubmit="@HandleValidSubmitAsync" FormName="CreateStatusForm">
    <DataAnnotationsValidator />
    <ValidationSummary />
    
    <div class="mb-3">
        <label for="Value" class="form-label">Value</label>
        <InputText class="form-control" type="text" id="Value"
                   @bind-Value="StatusModel.Value"/>
        <ValidationMessage For="() => StatusModel.Value" />
    </div>
    
    <div class="mb-3">
        <label for="Description" class="form-label">Description</label>
        <InputText class="form-control" type="text" id="Description"
                   @bind-Value="StatusModel.Description"/>
        <ValidationMessage For="() => StatusModel.Description" />
    </div>
    
    <div class="mb-3">
        <label for="Date" class="form-label">Date</label>
        <InputDate class="form-control" id="Date"
                   DisplayFormat="yyyy-MM-dd"
                   @bind-Value="StatusModel.TimeStamp" />
                
        <ValidationMessage For="() => StatusModel.TimeStamp" />
    </div>
    
    <button type="submit" class="btn btn-primary">Create</button>
    <a href="/status" class="btn btn-secondary ms-2">Cancel</a>
</EditForm>

@code {
    private string? _message;
    private AlertType? _alertType;

    [SupplyParameterFromForm(FormName = "CreateStatusForm")]
    private Status StatusModel { get; set; } = null!;

    protected override void OnInitialized()
    {
        StatusModel ??= new Status
        {
            Value = string.Empty,
            Description = string.Empty,
            TimeStamp = DateTime.UtcNow
        };
    }

    private async Task HandleValidSubmitAsync()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(StatusModel?.Value))
            {
                _message = "Value is required";
                _alertType = AlertType.Warning;
                return;
            }

            var result = await _statusClient.AddStatusAsync(StatusModel);
            
            await ShowAlert("Status created successfully.", AlertType.Success, 5000);

            // Reset form after successful creation
            StatusModel = new Status
            {
                Value = string.Empty,
                Description = string.Empty,
                TimeStamp = DateTime.UtcNow
            };
        }
        catch (Refit.ApiException ex)
        {
            await ShowAlert($"Error creating status: {ex.Message}", AlertType.Error, 5000);
        }
        catch (Exception ex)
        {
            await ShowAlert($"Unexpected error: {ex.Message}", AlertType.Error, 5000);
        }
    }
    
    private async Task ShowAlert(string message, AlertType type, int durationInMilliseconds = 0)
    {
        _message = message;
        _alertType = type;

        if (durationInMilliseconds > 0)
        {
            await Task.Delay(durationInMilliseconds);
            _message = null;
            _alertType = null;
        }
    }
}